# Postgres (shared by all services)
POSTGRES_USER=importer
POSTGRES_PASSWORD=importer
POSTGRES_DB=emissions
POSTGRES_PORT=5432

# Import service (NestJS)
IMPORT_SERVICE_PORT=3000
DATABASE_URL=postgresql://importer:importer@db:5432/emissions?schema=public

# Query service (FastAPI)
QUERY_SERVICE_PORT=8000
QUERY_RATE_LIMIT=60/minute
